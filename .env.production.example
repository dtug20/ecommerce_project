# ── Server ──
VPS_IP=YOUR_VPS_IP

# ── PostgreSQL (Keycloak DB) ──
PG_DB=keycloak
PG_USER=keycloak
PG_PASS=CHANGE_ME_strong_password_here

# ── Keycloak ──
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_strong_password_here
KEYCLOAK_HOSTNAME=http://YOUR_VPS_IP/auth

# ── Frontend build args ──
NEXT_PUBLIC_API_BASE_URL=http://YOUR_VPS_IP/api
NEXT_PUBLIC_KEYCLOAK_URL=http://YOUR_VPS_IP/auth
NEXT_PUBLIC_KEYCLOAK_REALM=shofy
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=shofy-frontend
