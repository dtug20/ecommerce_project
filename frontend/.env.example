# Frontend Environment Variables - Example Template
# =================================================
# Copy this file to .env.local and fill in your actual values

# API Configuration
NEXT_PUBLIC_API_BASE_URL=http://localhost:7001

# Keycloak Configuration
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8180
NEXT_PUBLIC_KEYCLOAK_REALM=shofy
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=shofy-frontend

# Stripe Configuration (Publishable Key)
NEXT_PUBLIC_STRIPE_KEY=pk_test_your-stripe-publishable-key

# App Configuration
NEXT_PUBLIC_APP_NAME=Shofy Electronics
NEXT_PUBLIC_APP_URL=http://localhost:3000
