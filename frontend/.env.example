# Frontend Environment Variables - Example Template
# =================================================
# Copy this file to .env.local and fill in your actual values

# API Configuration
NEXT_PUBLIC_API_BASE_URL=https://api.your-domain.com  # Your backend URL

# Stripe Configuration (Publishable Key)
NEXT_PUBLIC_STRIPE_KEY=pk_live_your-stripe-publishable-key  # Use pk_test_ for testing

# Google OAuth Configuration
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# App Configuration
NEXT_PUBLIC_APP_NAME=Shofy Electronics
NEXT_PUBLIC_APP_URL=https://your-domain.com