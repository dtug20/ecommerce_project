# Backend Environment Variables - Example Template
# =================================================
# Copy this file to .env and fill in your actual values
# NEVER commit actual secrets - only commit .env.example

# Server Configuration
PORT=7001
NODE_ENV=development

# Database Configuration (MongoDB)
MONGO_URI=mongodb://localhost:27017/shofy

# Keycloak Configuration
KEYCLOAK_BASE_URL=http://localhost:8180
KEYCLOAK_REALM=shofy
KEYCLOAK_CLIENT_ID=shofy-backend
KEYCLOAK_JWKS_URI=http://localhost:8180/realms/shofy/protocol/openid-connect/certs
KEYCLOAK_AUTHORITY=http://localhost:8180/realms/shofy
KEYCLOAK_CLIENT_SECRET=your-backend-client-secret
KEYCLOAK_ADMIN_CLIENT_ID=admin-cli
KEYCLOAK_ADMIN_CLIENT_SECRET=your-admin-client-secret

# CORS
STORE_URL=http://localhost:3001
ADMIN_URL=http://localhost:8081

# Cloudinary Configuration
CLOUDINARY_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
CLOUDINARY_UPLOAD_PRESET=your-cloudinary-upload-preset-name

# Email (nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
# Legacy email fields (used by older controllers)
SERVICE=gmail
HOST=smtp.gmail.com

# Stripe
STRIPE_KEY=sk_test_your-stripe-secret-key

# JWT / Token secrets (legacy auth — superseded by Keycloak in new routes)
TOKEN_SECRET=change-me-to-a-random-string
JWT_SECRET_FOR_VERIFY=change-me-to-another-random-string

# ISR Revalidation (used by Next.js frontend)
REVALIDATION_SECRET=change-me-to-a-random-string
