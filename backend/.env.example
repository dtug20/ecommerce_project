# Backend Environment Variables - Example Template
# =================================================
# Copy this file to .env and fill in your actual values
# NEVER commit actual secrets - only commit .env.example

# Server Configuration
PORT=7001
NODE_ENV=development

# Database Configuration (MongoDB)
MONGO_URI=mongodb://localhost:27017/shofy

# Keycloak Configuration
KEYCLOAK_JWKS_URI=http://localhost:8180/realms/shofy/protocol/openid-connect/certs
KEYCLOAK_CLIENT_ID=shofy-backend
KEYCLOAK_REALM=shofy
KEYCLOAK_AUTHORITY=http://localhost:8180/realms/shofy
KEYCLOAK_CLIENT_SECRET=your-backend-client-secret
KEYCLOAK_ADMIN_CLIENT_ID=admin-cli
KEYCLOAK_ADMIN_CLIENT_SECRET=your-admin-client-secret

# Cloudinary Configuration
CLOUDINARY_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
CLOUDINARY_UPLOAD_PRESET=your-cloudinary-upload-preset-name

# Stripe Configuration
STRIPE_KEY=sk_test_your-stripe-secret-key

# Frontend URLs
STORE_URL=http://localhost:3000
ADMIN_URL=http://localhost:8080
