<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Shofy CRM</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.0/font/bootstrap-icons.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <nav id="sidebar" class="col-md-3 col-lg-2 d-md-block bg-light sidebar collapse">
                <div class="position-sticky pt-3">
                    <div class="sidebar-header p-3 mb-3">
                        <h4><i class="bi bi-shop"></i> Shofy CRM</h4>
                    </div>
                    <ul class="nav flex-column">
                        <li class="nav-item">
                            <a class="nav-link <%= title.includes('Dashboard') ? 'active' : '' %>" href="/">
                                <i class="bi bi-speedometer2"></i> Dashboard
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link <%= title.includes('Product') ? 'active' : '' %>" href="/products">
                                <i class="bi bi-box-seam"></i> Products
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link <%= title.includes('Category') ? 'active' : '' %>" href="/categories">
                                <i class="bi bi-tags"></i> Categories
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link <%= title.includes('Order') ? 'active' : '' %>" href="/orders">
                                <i class="bi bi-bag-check"></i> Orders
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link <%= title.includes('User') ? 'active' : '' %>" href="/users">
                                <i class="bi bi-people"></i> Users
                            </a>
                        </li>
                    </ul>
                    <%- include('partials/user-info') %>
                </div>
            </nav>

            <!-- Main content -->
            <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
                <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                    <h1 class="h2"><%= title %></h1>
                </div>

                <!-- Alert container -->
                <div id="alertContainer"></div>

                <!-- Dashboard Stats Cards -->
                <div class="row mb-4">
                    <div class="col-xl-3 col-md-6 mb-4">
                        <div class="card border-left-primary shadow h-100 py-2">
                            <div class="card-body">
                                <div class="row no-gutters align-items-center">
                                    <div class="col mr-2">
                                        <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                                            Total Products
                                        </div>
                                        <div class="h5 mb-0 font-weight-bold text-gray-800" id="totalProducts">-</div>
                                    </div>
                                    <div class="col-auto">
                                        <i class="bi bi-box-seam fa-2x text-gray-300"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-xl-3 col-md-6 mb-4">
                        <div class="card border-left-success shadow h-100 py-2">
                            <div class="card-body">
                                <div class="row no-gutters align-items-center">
                                    <div class="col mr-2">
                                        <div class="text-xs font-weight-bold text-success text-uppercase mb-1">
                                            Total Orders
                                        </div>
                                        <div class="h5 mb-0 font-weight-bold text-gray-800" id="totalOrders">-</div>
                                    </div>
                                    <div class="col-auto">
                                        <i class="bi bi-bag-check fa-2x text-gray-300"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-xl-3 col-md-6 mb-4">
                        <div class="card border-left-info shadow h-100 py-2">
                            <div class="card-body">
                                <div class="row no-gutters align-items-center">
                                    <div class="col mr-2">
                                        <div class="text-xs font-weight-bold text-info text-uppercase mb-1">
                                            Total Users
                                        </div>
                                        <div class="h5 mb-0 font-weight-bold text-gray-800" id="totalUsers">-</div>
                                    </div>
                                    <div class="col-auto">
                                        <i class="bi bi-people fa-2x text-gray-300"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-xl-3 col-md-6 mb-4">
                        <div class="card border-left-warning shadow h-100 py-2">
                            <div class="card-body">
                                <div class="row no-gutters align-items-center">
                                    <div class="col mr-2">
                                        <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">
                                            Total Categories
                                        </div>
                                        <div class="h5 mb-0 font-weight-bold text-gray-800" id="totalCategories">-</div>
                                    </div>
                                    <div class="col-auto">
                                        <i class="bi bi-tags fa-2x text-gray-300"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Sync Section -->
                <div class="row mb-4">
                    <div class="col-12">
                        <div class="card shadow">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <h5 class="mb-0"><i class="bi bi-arrow-repeat"></i> Frontend Synchronization</h5>
                                <span id="syncStatus" class="badge bg-secondary">Unknown</span>
                            </div>
                            <div class="card-body">
                                <p class="text-muted">Keep your frontend website synchronized with CRM changes. All updates made in the CRM will automatically sync to your e-commerce website.</p>
                                
                                <div id="syncStatusDetails" class="mb-3">
                                    <div class="row text-center">
                                        <div class="col-md-4">
                                            <h6>Products</h6>
                                            <span id="productsSync" class="badge bg-secondary">-</span>
                                        </div>
                                        <div class="col-md-4">
                                            <h6>Categories</h6>
                                            <span id="categoriesSync" class="badge bg-secondary">-</span>
                                        </div>
                                        <div class="col-md-4">
                                            <h6>Users</h6>
                                            <span id="usersSync" class="badge bg-secondary">-</span>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="btn-group" role="group">
                                    <button type="button" class="btn btn-primary" onclick="syncAll()">
                                        <i class="bi bi-arrow-clockwise"></i> Sync All
                                    </button>
                                    <button type="button" class="btn btn-outline-primary" onclick="syncProducts()">
                                        <i class="bi bi-box-seam"></i> Products Only
                                    </button>
                                    <button type="button" class="btn btn-outline-primary" onclick="syncCategories()">
                                        <i class="bi bi-tags"></i> Categories Only
                                    </button>
                                    <button type="button" class="btn btn-outline-primary" onclick="syncUsers()">
                                        <i class="bi bi-people"></i> Users Only
                                    </button>
                                    <button type="button" class="btn btn-outline-secondary" onclick="checkSyncStatus()">
                                        <i class="bi bi-info-circle"></i> Check Status
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Recent Activity -->
                <div class="row">
                    <div class="col-lg-6 mb-4">
                        <div class="card shadow mb-4">
                            <div class="card-header py-3">
                                <h6 class="m-0 font-weight-bold text-primary">Recent Orders</h6>
                            </div>
                            <div class="card-body">
                                <div class="table-responsive">
                                    <table class="table table-bordered" id="recentOrdersTable">
                                        <thead>
                                            <tr>
                                                <th>Order #</th>
                                                <th>Customer</th>
                                                <th>Amount</th>
                                                <th>Status</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <!-- Data will be loaded via JavaScript -->
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-6 mb-4">
                        <div class="card shadow mb-4">
                            <div class="card-header py-3">
                                <h6 class="m-0 font-weight-bold text-primary">Low Stock Products</h6>
                            </div>
                            <div class="card-body">
                                <div class="table-responsive">
                                    <table class="table table-bordered" id="lowStockTable">
                                        <thead>
                                            <tr>
                                                <th>Product</th>
                                                <th>Quantity</th>
                                                <th>Status</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <!-- Data will be loaded via JavaScript -->
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Charts -->
                <div class="row">
                    <div class="col-lg-6 mb-4">
                        <div class="card shadow mb-4">
                            <div class="card-header py-3">
                                <h6 class="m-0 font-weight-bold text-primary">Monthly Sales</h6>
                            </div>
                            <div class="card-body">
                                <canvas id="monthlySalesChart"></canvas>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-6 mb-4">
                        <div class="card shadow mb-4">
                            <div class="card-header py-3">
                                <h6 class="m-0 font-weight-bold text-primary">Order Status Distribution</h6>
                            </div>
                            <div class="card-body">
                                <canvas id="orderStatusChart"></canvas>
                            </div>
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="/js/app.js"></script>
    <script src="/js/dashboard.js"></script>
</body>
</html>