# CRM Environment Variables - Example Template
# =============================================
# Copy this file to .env and fill in your actual values

# Server
NODE_ENV=development
CRM_PORT=8081

# Backend API (CRM proxies all data requests to the backend)
BACKEND_API_URL=http://localhost:4000

# MongoDB (direct connection used during transition period)
MONGO_URI=mongodb://localhost:27017/shofy

# Session
SESSION_SECRET=change-me-to-a-random-string

# Keycloak
KEYCLOAK_BASE_URL=http://localhost:8180
KEYCLOAK_REALM=shofy
KEYCLOAK_CRM_CLIENT_ID=shofy-crm
KEYCLOAK_CRM_SECRET=change-me-to-crm-client-secret
