# CRM Environment Variables
# =========================

# Server
CRM_PORT=8080
NODE_ENV=development

# MongoDB (same database as backend)
MONGO_URI=mongodb://localhost:27017/shofy

# Keycloak
KEYCLOAK_BASE_URL=http://localhost:8180
KEYCLOAK_REALM=shofy
KEYCLOAK_CRM_CLIENT_ID=shofy-crm
KEYCLOAK_CRM_SECRET=CHANGE_ME_CRM_SECRET

# Session
SESSION_SECRET=your-random-session-secret-here
